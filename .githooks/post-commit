#!/usr/bin/env sh
# post-commit hook — auto-insert CHANGELOG entry and amend the commit.
#
# Historical note: this hook used to insert a CHANGELOG bullet and silently
# amend the commit. That made commit identity unstable for both humans and
# agents, and it invalidated the pre-push CI cache. The hook is now advisory
# only: it reminds the user to update CHANGELOG.md explicitly.
#
# Skip conditions:
#   DRIFT_SKIP_CHANGELOG=1   bypass entirely (set internally to prevent loops)
#   Merge / fixup / squash   commits are skipped automatically
#   Non-conventional commits silently skipped by the Python script

set -e

# Loop guard: the amend triggers another post-commit run; skip it.
if [ "${DRIFT_SKIP_CHANGELOG:-0}" = "1" ]; then
    exit 0
fi

# Git sets GIT_DIR; resolve COMMIT_EDITMSG portably.
git_dir="$(git rev-parse --git-dir)"
commit_msg_file="${git_dir}/COMMIT_EDITMSG"

if [ ! -f "$commit_msg_file" ]; then
    exit 0
fi

# Skip merge / fixup / squash commits.
first_line="$(head -1 "$commit_msg_file")"
case "$first_line" in
    Merge\ *|fixup\!\ *|squash\!\ *)
        exit 0 ;;
esac

# Locate the Python interpreter (prefer the venv used by the project).
if [ -f ".venv/Scripts/python.exe" ]; then
    PYTHON=".venv/Scripts/python.exe"
elif [ -f ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"
else
    PYTHON="python"
fi

# Check whether this commit type normally requires a changelog update.
parsed=$(
    "$PYTHON" - <<'PY' "$commit_msg_file"
from pathlib import Path
import re
import sys

first = Path(sys.argv[1]).read_text(encoding="utf-8").splitlines()[0].strip()
match = re.match(r"^(feat|fix|chore)(?:\([^)]*\))?!?:\s+(.+)", first, re.IGNORECASE)
if not match:
    raise SystemExit(0)
print(match.group(1).lower())
PY
)

if [ -n "$parsed" ]; then
    echo ">>> [post-commit] Reminder: update CHANGELOG.md explicitly (for example: make changelog-insert COMMIT_TYPE=$parsed MSG='<summary>')." >&2
fi
